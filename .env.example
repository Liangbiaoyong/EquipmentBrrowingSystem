# ─── 数据库 ───────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root123
MYSQL_USER=devuser
MYSQL_PASSWORD=devpass

# ─── 对象存储 MinIO ────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# ─── CAS 统一认证 ───────────────────────────────────────
# CAS用户信息验证API地址
CAS_USERINFO_URL=https://libbooking.gzhu.edu.cn/ic-web/auth/userInfo
# CAS请求超时（毫秒）
CAS_REQUEST_TIMEOUT=15000
# CAS服务端地址（记录用途）
CAS_SERVER_URL=https://newcas.gzhu.edu.cn/cas

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production-use-at-least-256-bits
